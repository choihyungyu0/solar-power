# Copy this file to .env.local for local development.
# Do not commit .env.local.
# Register localhost and the Vercel deployment domain in the VWorld developer center.
# Keep VITE_VWORLD_3D_SDK_URL as the base SDK URL only. Do not include ?version=3.0.
# VITE_VWORLD_BUILDING_DATA_ID should be a building, roof, or building-facility dataset when available.
# LP_PA_CBND_BUBUN is cadastral parcel data and is only suitable for a clearly labeled fallback, not exact roof geometry.
# npm.cmd run dev only runs Vite and does not serve Vercel Functions under /api.
# To test server proxies such as VWorld and PV analysis locally,
# run npx vercel dev, then open http://localhost:3000/risk-map.
# climate.gg live analysis is disabled in the production UI by default.
# Future live analysis should call a separate backend server, not a Vercel Function.
# Do not call climate.gg directly from browser code.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use the Supabase anon/public browser key only. Never put a service_role key in any VITE_ variable.
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_VWORLD_API_KEY=your_vworld_api_key
VITE_VWORLD_3D_SDK_URL=https://map.vworld.kr/js/webglMapInit.js.do
VITE_VWORLD_3D_VERSION=3.0
VITE_VWORLD_BUILDING_DATA_ID=LP_PA_CBND_BUBUN
VITE_MAP_LEFT_CLICK_SELECT_ONLY=true
VITE_SHOW_PANEL_DEBUG_ENTITY=false
VITE_LIFT_SOLAR_PANELS_DEBUG=false
VITE_ENABLE_CLIMATE_LIVE_BACKEND=false
VITE_CLIMATE_BACKEND_BASE_URL=
VWORLD_API_KEY=your_server_side_vworld_key
VWORLD_DOMAIN=http://localhost:5173

# Hwaseong-si real building polygon source.
# Use "admdong_index" to load index.json first, then fetch only bbox candidate GeoJSON files.
# Use "geojson" only for a single small file.
# Use "api" when BUILDING_POLYGON_API_URL is connected to the data team's building polygon API.
VITE_BUILDING_POLYGON_SOURCE=admdong_index
VITE_BUILDING_ADMDONG_INDEX_URL=/data/buildings/hwaseong_buildings_v1_by_admdong/index.json
VITE_BUILDING_META_URL=/data/buildings/hwaseong_buildings_v1_meta.json
VITE_BUILDING_FOOTPRINT_GEOJSON_URL=/data/buildings/hwaseong-buildings.geojson
BUILDING_POLYGON_API_URL=
BUILDING_POLYGON_API_KEY=
