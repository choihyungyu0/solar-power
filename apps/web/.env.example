# Copy this file to .env.local for local development.
# Do not commit .env.local.
# Register localhost and the Vercel deployment domain in the VWorld developer center.
# Keep VITE_VWORLD_3D_SDK_URL as the base SDK URL only. Do not include ?version=3.0.
# VITE_VWORLD_BUILDING_DATA_ID should be a building, roof, or building-facility dataset when available.
# LP_PA_CBND_BUBUN is cadastral parcel data and is only suitable for a clearly labeled fallback, not exact roof geometry.
# npm.cmd run dev only runs Vite and does not serve Vercel Functions under /api.
# To test the VWorld feature proxy locally, run npx vercel dev, then open http://localhost:3000/risk-map.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_VWORLD_API_KEY=your_vworld_api_key
VITE_VWORLD_3D_SDK_URL=https://map.vworld.kr/js/webglMapInit.js.do
VITE_VWORLD_3D_VERSION=3.0
VITE_VWORLD_BUILDING_DATA_ID=LP_PA_CBND_BUBUN
VWORLD_API_KEY=your_server_side_vworld_key
VWORLD_DOMAIN=http://localhost:5173

# Hwaseong-si real building polygon source.
# Use "geojson" when the data team provides apps/web/public/data/buildings/hwaseong-buildings.geojson.
# Use "api" when BUILDING_POLYGON_API_URL is connected to the data team's building polygon API.
VITE_BUILDING_POLYGON_SOURCE=geojson
VITE_BUILDING_FOOTPRINT_GEOJSON_URL=/data/buildings/hwaseong-buildings.geojson
BUILDING_POLYGON_API_URL=
BUILDING_POLYGON_API_KEY=
