### Production climate analysis insert test
POST https://solarmate-climate-backend.onrender.com/api/climate-rooftop-analysis
Content-Type: application/json

{
  "longitude": 127.072254,
  "latitude": 37.202501,
  "selectedBuildingId": "manual-supabase-test",
  "selectedAnalysisSessionId": "manual-supabase-test-session",
  "selectedBuildingFeature": {
    "type": "Feature",
    "properties": {
      "bld_id": "manual-supabase-test",
      "bld_nm": "수동 Supabase 테스트 건물",
      "address": "경기도 화성시 테스트 주소"
    },
    "geometry": {
      "type": "Polygon",
      "coordinates": [[
        [127.07220, 37.20245],
        [127.07235, 37.20245],
        [127.07235, 37.20260],
        [127.07220, 37.20260],
        [127.07220, 37.20245]
      ]]
    }
  },
  "panelCapacityW": 640,
  "panelAngle": 35,
  "panelType": 1,
  "cellsPerPanel": 2,
  "mode": "fast"
}

