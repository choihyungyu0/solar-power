### Climate backend health
GET http://localhost:8001/health

### Climate backend analysis test minimal
POST http://localhost:8001/api/climate-rooftop-analysis
Content-Type: application/json

{
  "longitude": 127.072254,
  "latitude": 37.202501,
  "selectedBuildingId": "manual-test",
  "selectedBuildingFeature": {
    "type": "Feature",
    "properties": {
      "bld_id": "manual-test"
    },
    "geometry": {
      "type": "Polygon",
      "coordinates": [[
        [127.07220, 37.20245],
        [127.07235, 37.20245],
        [127.07235, 37.20260],
        [127.07220, 37.20260],
        [127.07220, 37.20245]
      ]]
    }
  },
  "panelCapacityW": 640,
  "panelAngle": 35,
  "panelType": 1,
  "cellsPerPanel": 2,
  "mode": "fast"
}

