### Production consultation insert test
POST https://solarmate-climate-backend.onrender.com/api/consultations
Content-Type: application/json

{
  "name": "테스트사용자",
  "contact": "010-0000-0000",
  "email": "test@example.com",
  "consultationType": "설치 가능 여부 상담",
  "content": "Supabase 상담 저장 테스트입니다.",
  "roadAddress": "경기도 화성시 테스트 주소",
  "jibunAddress": "경기도 화성시 테스트 지번",
  "analysisResultId": "{{paste_analysisResultId_from_previous_response}}",
  "privacyAgreed": true,
  "thirdPartyAgreed": false,
  "agentPayload": {
    "summaryForCounselor": "수동 테스트 상담 payload입니다.",
    "nextStep": "저장 확인"
  }
}

